{
  "permissions": {
    "allow": [
      "Read(src/**/*.ts)",
      "Read(src/**/*.tsx)",
      "Read(src/**/*.json)",
      "Read(*.md)",
      "Read(.gitignore)",
      "Write(CONTEXT.md)",
      "Write(CLAUDE.md)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run sim)",
      "Bash(npm run sim:batch)",
      "Bash(npm run sim *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx tsc --noEmit *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)"
    ]
  }
}
